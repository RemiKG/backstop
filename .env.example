# Backstop — environment. Copy to .env.local and fill in. NEVER commit real values.
# All of these are read SERVER-SIDE only; none are exposed to the browser.

# Splunk Cloud over the 443 web-REST proxy (session login). 443 is public, so this works
# from local dev and from any deployed backend.
SPLUNK_URL=https://your-stack.splunkcloud.com
SPLUNK_USER=your_user
SPLUNK_PASS=your_password
# SPLUNK_LOCALE=en-GB   # optional, default en-GB

# Gemini (Vertex AI) — the agent's reasoning brain. Provide the service account EITHER as a
# file path (local dev / Cloud Run) OR inline as an env var (serverless hosts like Vercel that
# have no writable key file). The inline value may be raw JSON or base64-encoded JSON.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/vertex-sa.json
# VERTEX_SA_JSON={"type":"service_account",...}   # use this instead of the path on Vercel
VERTEX_PROJECT=rapid-agents-5166
VERTEX_LOCATION=global
VERTEX_MODEL=gemini-flash-latest

# Index Backstop seeds the SAMPLE demo estate into (and probes for the live flip).
BACKSTOP_DEMO_INDEX=backstop_demo

# OPTIONAL — Splunk AI primitives (honest seams; activate the moment the value exists).
# Foundation-sec Hosted Model endpoint. If unset, exposure ranking uses the transparent
# cron/action/category severity heuristic (mode is shown on every badge).
# FOUNDATION_SEC_URL=
# FOUNDATION_SEC_KEY=
